{% assign suggestion_terms = 'bagel,avocado,grillen,dip,geschenk,nachfüllpack' | split: ',' %}

<section class="sf-search-page">
  <div class="sf-page">
    <nav class="sf-breadcrumb" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">Start</a>
      <span aria-hidden="true">/</span>
      <span aria-current="page">Suche</span>
    </nav>

    {% if search.performed %}
      <div class="sf-search-summary">
        <div>
          <p class="sf-eyebrow">Suchergebnis</p>
          <h1>
            {% if search.results_count == 0 %}
              Keine Treffer für “{{ search.terms | escape }}”
            {% else %}
              {{ search.results_count }} Treffer für “{{ search.terms | escape }}”
            {% endif %}
          </h1>
        </div>
        <a class="sf-button sf-button--ghost" href="{{ routes.collections_url }}/gewuerzmischungen">Sortiment ansehen</a>
      </div>

      {% if search.results_count == 0 %}
        <div class="sf-search-empty">
          <p class="sf-eyebrow">Besserer Einstieg</p>
          <h2>Versuche einen Kochanlass statt eines Produktnamens.</h2>
          <p>
            Viele Gewürzkäufe starten nicht mit einer exakten SKU, sondern mit “Brunch”, “Grillen”,
            “Dip” oder “Geschenk”. Diese Pfade führen schneller zur passenden Auswahl.
          </p>
          <div class="sf-search-suggestions">
            {% for term in suggestion_terms limit: 4 %}
              <a class="sf-chip" href="{{ routes.search_url }}?type=product&q={{ term | url_encode }}">{{ term | capitalize }}</a>
            {% endfor %}
          </div>
        </div>
      {% else %}
        {% paginate search.results by 24 %}
          <div class="sf-search-results">
            {% for result in search.results %}
              {% if result.object_type == 'product' %}
                {% render 'product-card-spice', product: result %}
              {% else %}
                <article class="sf-search-result-card">
                  {% assign featured_image = result.featured_image | default: result.image %}
                  {% if featured_image %}
                    <a class="sf-search-result-card__image" href="{{ result.url }}">
                      {% render 'image',
                        image: featured_image,
                        width: 720,
                        height: 520,
                        crop: 'center',
                        loading: 'lazy',
                        sizes: '(min-width: 990px) 33vw, 100vw'
                      %}
                    </a>
                  {% endif %}
                  <div>
                    <p class="sf-eyebrow">{{ result.object_type | capitalize }}</p>
                    <h3><a href="{{ result.url }}">{{ result.title }}</a></h3>
                    {% if result.content != blank %}
                      <p>{{ result.content | strip_html | truncate: 150 }}</p>
                    {% endif %}
                  </div>
                </article>
              {% endif %}
            {% endfor %}
          </div>
          <div class="sf-pagination">{{ paginate | default_pagination }}</div>
        {% endpaginate %}
      {% endif %}
    {% else %}
      <div class="sf-search-summary">
        <div>
          <p class="sf-eyebrow">Shop Discovery</p>
          <h1>Wähle einen schnellen Einstieg.</h1>
        </div>
      </div>

      <div class="sf-search-intent-grid" aria-label="Suchpfade">
        <a href="{{ routes.search_url }}?type=product&q=brunch">
          <span>01</span>
          <strong>Brunch</strong>
          <small>Bagel, Avocado, Ei und Bowls.</small>
        </a>
        <a href="{{ routes.search_url }}?type=product&q=grillen">
          <span>02</span>
          <strong>Grillen</strong>
          <small>Kräuterbutter, Gemüse, Dips und Sets.</small>
        </a>
        <a href="{{ routes.search_url }}?type=product&q=geschenk">
          <span>03</span>
          <strong>Geschenke</strong>
          <small>Kuratierte Sets für Gastgeber und Teams.</small>
        </a>
      </div>
    {% endif %}

    <div class="sf-search-hero sf-search-hero--bottom">
      <p class="sf-eyebrow">Suche nach Anlass</p>
      <h2 class="sf-heading sf-heading--medium">Finde die richtige Würze über Gericht, Aroma oder Anlass.</h2>
      <p class="sf-copy">
        Suche nach Zutaten, Rezeptideen, Geschenkpfaden oder Vorratsgrößen. Gute Suche ist hier kein
        Notausgang, sondern ein schneller Kaufpfad.
      </p>

      <form class="sf-search-form" action="{{ routes.search_url }}" method="get" role="search">
        <label class="visually-hidden" for="SearchPage-{{ section.id }}">Suchbegriff</label>
        <input
          id="SearchPage-{{ section.id }}"
          type="search"
          name="q"
          value="{{ search.terms | escape }}"
          placeholder="z. B. Bagel, Avocado, Grillen oder Geschenk"
          autocomplete="off"
        >
        <input type="hidden" name="type" value="product">
        <button class="sf-button" type="submit">Suchen</button>
      </form>

      <div class="sf-search-suggestions" aria-label="Beliebte Suchpfade">
        {% for term in suggestion_terms %}
          <a class="sf-chip" href="{{ routes.search_url }}?type=product&q={{ term | url_encode }}">{{ term | capitalize }}</a>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:general.search",
  "settings": []
}
{% endschema %}
