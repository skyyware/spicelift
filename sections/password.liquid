{% comment %}
  Password template for password-protected dev-store previews.
{% endcomment %}

<section class="sf-password full-width">
  <div class="sf-page sf-password__inner">
    <div class="sf-password__content">
      <a class="sf-logo" href="{{ routes.root_url }}">
        <span class="sf-logo__wordmark">RIMOCO</span>
        <span class="sf-logo__tagline">Shopify Growth Preview</span>
      </a>

      <p class="sf-eyebrow">Unpublished Shopify Theme im Dev Store Spicelift</p>
      <h1 class="sf-heading">Eine echte Store-Preview für Bio-Gewürze, Rezepte und Sets.</h1>
      <p class="sf-copy">
        Diese Arbeitsprobe ist als Shopify Theme gebaut und mit Produkten, Varianten,
        Metafields und Collections im Dev Store befüllt. Der vollständige Store ist
        passwortgeschützt; die Vorschau zeigt bereits Struktur, Tonalität und technische Richtung.
      </p>

      <div class="sf-password__proof">
        <span>Liquid Theme</span>
        <span>Produktvarianten</span>
        <span>Recipe-to-Cart</span>
        <span>Shopify Metafields</span>
      </div>

      <div class="sf-password__form">
        {% form 'storefront_password' %}
          {% if form.errors %}
            {{ form.errors | default_errors }}
          {% endif %}

          <label for="password-input">Storefront-Passwort</label>
          <div class="sf-password__row">
            <input type="password" name="password" id="password-input" autocomplete="current-password">
            <button class="sf-button" type="submit">{{ 'password.enter' | t }}</button>
          </div>
        {% endform %}
      </div>
    </div>

    <div class="sf-password__preview" aria-label="Store Preview">
      <div class="sf-password__card">
        <span class="sf-bio-badge">Bio</span>
        <div class="sf-jar" aria-hidden="true">
          <div class="sf-jar__label">Bagel Gewürz</div>
        </div>
        <strong>Bio Bagel Gewürz</strong>
        <p>Varianten sichtbar machen: Dose, Nachfüllpack und Gastro-Größe.</p>
      </div>
      <div class="sf-password__card sf-password__card--alt">
        <p class="sf-eyebrow">Recipe-to-Cart</p>
        <h2>Knusprige Bagel Bowl</h2>
        <p>Rezept-Content wird zur Einkaufsstrecke statt nur zur Inspiration.</p>
        <div class="sf-chip-row">
          <span class="sf-chip">Avocado</span>
          <span class="sf-chip">Bagel</span>
          <span class="sf-chip">Nachfüllbar</span>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:general.password",
  "settings": []
}
{% endschema %}
