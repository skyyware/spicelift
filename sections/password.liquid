{% comment %}
  Password template for the Spicelift dev store preview.
{% endcomment %}

<section class="sf-password-preview full-width">
  <div class="sf-password-preview__box">
    <a class="sf-logo" href="{{ routes.root_url }}">
      <span class="sf-logo__mark" aria-hidden="true">S</span>
      <span class="sf-logo__text">
        <span class="sf-logo__wordmark">SPICELIFT</span>
        <span class="sf-logo__tagline">Bio Gewürzmanufaktur</span>
      </span>
    </a>
    <p class="sf-eyebrow" style="color:#d9e6c4;margin-top:34px;">Shop geschützt</p>
    <h1 class="sf-heading">Premium-Gewürze, Rezeptideen und Sets in einem ruhigen Shopify-Erlebnis.</h1>
    <p class="sf-copy" style="color:rgba(255,255,255,.78);">
      Dieser Shop ist passwortgeschützt. Mit Passwort öffnet sich der vollständige
      Spicelift-Shop mit Produkten, Varianten, Collections und Rezeptstrecken.
    </p>

    <div style="margin-top:30px;">
      {% form 'storefront_password' %}
        {% if form.errors %}
          {{ form.errors | default_errors }}
        {% endif %}
        <label for="password-input" style="display:block;margin-bottom:10px;">Shop-Passwort</label>
        <div style="display:grid;grid-template-columns:1fr auto;gap:10px;">
          <input type="password" name="password" id="password-input" autocomplete="current-password">
          <button class="sf-button sf-button--light" type="submit">{{ 'password.enter' | t }}</button>
        </div>
      {% endform %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:general.password",
  "settings": []
}
{% endschema %}
