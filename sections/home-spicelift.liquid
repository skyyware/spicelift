{% assign spice_collection = collections['gewuerzmischungen'] %}
{% assign set_collection = collections['gewuerzsets'] %}
{% assign spice_collection_url = routes.collections_url | append: '/gewuerzmischungen' %}
{% assign set_collection_url = routes.collections_url | append: '/gewuerzsets' %}
{% assign bagel = all_products['bio-bagel-gewuerz'] %}
{% assign avocado = all_products['bio-avocado-gewuerz'] %}
{% assign cafe = all_products['bio-cafe-de-paris-gewuerz'] %}
{% assign bruehe = all_products['bio-gemuesebruehe'] %}
{% assign grill_set = all_products['bio-grillabend-set'] %}
{% assign brunch_set = all_products['bio-brunch-bagel-set'] %}

<section class="sf-hero full-width">
  <img
    class="sf-hero__image"
    src="{{ 'spice-hero-premium.jpg' | asset_url }}"
    width="2000"
    height="1400"
    loading="eager"
    fetchpriority="high"
    alt=""
  >
  <div class="sf-page sf-hero__inner">
    <p class="sf-eyebrow">Bio Gewürze aus der Manufaktur</p>
    <h1 class="sf-heading">Gewürze, die jedes Gericht auf den Punkt bringen.</h1>
    <p class="sf-copy">
      Intensive Bio-Gewürze, kuratierte Sets und einfache Rezeptideen für Küche,
      Geschenk und Vorrat. Klar in der Auswahl, hochwertig im Geschmack.
    </p>
    <div class="sf-hero__actions">
      <a class="sf-button" href="{{ spice_collection_url }}">Gewürze entdecken</a>
      <a class="sf-button sf-button--on-dark" href="#recipe-to-cart">Rezept des Tages</a>
    </div>
    <div class="sf-hero__proof" aria-label="Spicelift Vorteile">
      <div class="sf-proof-item"><strong>100% Bio</strong><span>Ausgewählte Rohstoffe und klare Zutaten.</span></div>
      <div class="sf-proof-item"><strong>4,94 / 5</strong><span>Vertrauen direkt vor der Kaufentscheidung.</span></div>
      <div class="sf-proof-item"><strong>Ab 40 €</strong><span>Versandkostenfrei in Deutschland.</span></div>
    </div>
  </div>
</section>

<section class="sf-category-strip full-width" aria-label="Kategorien">
  <div class="sf-page sf-category-list">
    <a class="sf-category-card" href="{{ spice_collection_url }}">
      <span class="sf-category-card__image"><img src="{{ 'spice-product-bio-bagel-gewuerz.jpg' | asset_url }}" alt="" width="144" height="144" loading="lazy"></span>
      <strong>Gewürzmischungen<span>Für Alltag, Grillen, Dips und Bowls</span></strong>
    </a>
    <a class="sf-category-card" href="{{ set_collection_url }}">
      <span class="sf-category-card__image"><img src="{{ 'spice-product-bio-grillabend-set.jpg' | asset_url }}" alt="" width="144" height="144" loading="lazy"></span>
      <strong>Geschenksets<span>Für Küche, Kundschaft und Gastgeber</span></strong>
    </a>
    <a class="sf-category-card" href="#recipe-to-cart">
      <span class="sf-category-card__image"><img src="{{ 'spice-product-bio-avocado-gewuerz.jpg' | asset_url }}" alt="" width="144" height="144" loading="lazy"></span>
      <strong>Rezepte<span>Vom Anlass direkt zum Warenkorb</span></strong>
    </a>
    <a class="sf-category-card" href="#b2b">
      <span class="sf-category-card__image"><img src="{{ 'spice-product-bio-brunch-bagel-set.jpg' | asset_url }}" alt="" width="144" height="144" loading="lazy"></span>
      <strong>B2B<span>Firmengeschenke und Private Label</span></strong>
    </a>
  </div>
</section>

<section class="sf-section sf-finder-section" id="aroma-finder">
  <div class="sf-page sf-finder">
    <div class="sf-finder__copy">
      <p class="sf-eyebrow">Aroma-Finder</p>
      <h2 class="sf-heading sf-heading--medium">Nicht suchen. Passend würzen.</h2>
      <p class="sf-copy">
        Der schnellste Weg zum richtigen Produkt ist nicht die Produktliste, sondern der Kochanlass.
        Eine einfache Beratungsschicht senkt Auswahlstress und führt direkt zu Dose, Refill oder Set.
      </p>
      <div class="sf-finder__metrics" aria-label="Commerce-Hebel">
        <span><strong>1</strong> Anlass</span>
        <span><strong>2</strong> Empfehlungen</span>
        <span><strong>0</strong> Suchweg</span>
      </div>
    </div>

    <div class="sf-finder__panel" data-finder>
      <div class="sf-finder__choices" role="tablist" aria-label="Kochanlass auswählen">
        <button class="sf-finder-choice is-active" type="button" role="tab" aria-selected="true" data-finder-target="brunch">
          <span>Brunch</span>
          <small>Bagel, Avocado, Ei</small>
        </button>
        <button class="sf-finder-choice" type="button" role="tab" aria-selected="false" data-finder-target="grill">
          <span>Grillen</span>
          <small>Gemüse, Dip, Butter</small>
        </button>
        <button class="sf-finder-choice" type="button" role="tab" aria-selected="false" data-finder-target="alltag">
          <span>Alltag</span>
          <small>Suppe, Risotto, Meal Prep</small>
        </button>
        <button class="sf-finder-choice" type="button" role="tab" aria-selected="false" data-finder-target="geschenk">
          <span>Geschenk</span>
          <small>Kuratierte Sets</small>
        </button>
      </div>

      <div class="sf-finder-results">
        <div class="sf-finder-result is-active" data-finder-result="brunch">
          <div>
            <p class="sf-eyebrow">Empfehlung</p>
            <h3>Frisch, nussig, sofort verständlich.</h3>
            <p>Bagel-Gewürz und Avocado-Gewürz bilden einen einfachen Brunch-Pfad mit hoher Wiederkauflogik.</p>
          </div>
          <div class="sf-finder-products">
            {% if bagel != blank %}{% render 'product-card-spice', product: bagel, compact: true %}{% endif %}
            {% if avocado != blank %}{% render 'product-card-spice', product: avocado, compact: true %}{% endif %}
          </div>
        </div>

        <div class="sf-finder-result" data-finder-result="grill" hidden>
          <div>
            <p class="sf-eyebrow">Empfehlung</p>
            <h3>Kräuterbutter, Grillgemüse, Geschenk.</h3>
            <p>Café de Paris plus Grillabend-Set macht aus einzelnen Produkten einen Anlasskorb.</p>
          </div>
          <div class="sf-finder-products">
            {% if cafe != blank %}{% render 'product-card-spice', product: cafe, compact: true %}{% endif %}
            {% if grill_set != blank %}{% render 'product-card-spice', product: grill_set, compact: true %}{% endif %}
          </div>
        </div>

        <div class="sf-finder-result" data-finder-result="alltag" hidden>
          <div>
            <p class="sf-eyebrow">Empfehlung</p>
            <h3>Basis für die schnelle Küche.</h3>
            <p>Gemüsebrühe und Avocado-Gewürz lösen zwei wiederkehrende Fälle: Basis und frisches Finish.</p>
          </div>
          <div class="sf-finder-products">
            {% if bruehe != blank %}{% render 'product-card-spice', product: bruehe, compact: true %}{% endif %}
            {% if avocado != blank %}{% render 'product-card-spice', product: avocado, compact: true %}{% endif %}
          </div>
        </div>

        <div class="sf-finder-result" data-finder-result="geschenk" hidden>
          <div>
            <p class="sf-eyebrow">Empfehlung</p>
            <h3>Auswahl ohne Geschenkrisiko.</h3>
            <p>Kuratierte Sets funktionieren für Gastgeber, Kundengeschenke und saisonale Kampagnen.</p>
          </div>
          <div class="sf-finder-products">
            {% if brunch_set != blank %}{% render 'product-card-spice', product: brunch_set, compact: true %}{% endif %}
            {% if grill_set != blank %}{% render 'product-card-spice', product: grill_set, compact: true %}{% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="sf-section" id="favorites">
  <div class="sf-page">
    <div class="sf-section-intro">
      <div>
        <p class="sf-eyebrow">Beliebt in der Küche</p>
        <h2 class="sf-heading sf-heading--medium">Schneller vom Kochanlass zum richtigen Aroma.</h2>
      </div>
      <div class="sf-chip-row" aria-label="Kochanlässe">
        <a class="sf-chip" href="{{ spice_collection_url }}">Zum Grillen</a>
        <a class="sf-chip" href="{{ spice_collection_url }}">Für Salate</a>
        <a class="sf-chip" href="{{ spice_collection_url }}">Für Dips</a>
        <a class="sf-chip" href="{{ set_collection_url }}">Als Geschenk</a>
      </div>
    </div>

    <div class="sf-grid sf-grid--4">
      {% if spice_collection.products.size > 0 %}
        {% for product in spice_collection.products limit: 4 %}
          {% render 'product-card-spice', product: product %}
        {% endfor %}
      {% else %}
        <p>Produkte werden bald angezeigt.</p>
      {% endif %}
    </div>
  </div>
</section>

<section class="sf-section sf-usecase full-width" id="recipe-to-cart">
  <div class="sf-page sf-usecase-grid">
    <div class="sf-recipe-card">
      <p class="sf-eyebrow">Rezept des Tages</p>
      <h2>Knusprige Bagel Bowl mit Avocado-Dip.</h2>
      <p class="sf-copy">Ein schneller Brunch-Favorit mit zwei Gewürzen, die Bagel, Avocado und Dip zusammenbringen.</p>
    </div>

    <div class="sf-recipe-stack">
      <div class="sf-recipe-step is-current">
        <span>01</span>
        <div>
          <h3>Rezept als Warenkorb denken</h3>
          <p>Das Rezept erklärt nicht nur, es führt direkt zu den passenden Produkten.</p>
        </div>
      </div>
      <div class="sf-recipe-step">
        <span>02</span>
        <div>
          <h3>Dose und Refill sichtbar machen</h3>
          <p>Für Erstkauf und Wiederkauf entsteht ein klarer nächster Schritt.</p>
        </div>
      </div>
      <div class="sf-grid sf-grid--2">
        {% if bagel != blank %}{% render 'product-card-spice', product: bagel %}{% endif %}
        {% if avocado != blank %}{% render 'product-card-spice', product: avocado %}{% endif %}
      </div>
      {% if bagel != blank and avocado != blank %}
        <button
          class="sf-button sf-bundle-button"
          type="button"
          data-bundle-add
          data-items='[{"id":{{ bagel.selected_or_first_available_variant.id | json }},"quantity":1},{"id":{{ avocado.selected_or_first_available_variant.id | json }},"quantity":1}]'
        >
          Rezeptkorb hinzufügen
        </button>
        <p class="sf-bundle-note" data-bundle-note>Fügt Bagel-Gewürz und Avocado-Gewürz in den Warenkorb.</p>
      {% endif %}
    </div>
  </div>
</section>

<section class="sf-section sf-editorial full-width" id="manufaktur">
  <div class="sf-page sf-editorial-grid">
    <div class="sf-editorial-image">
      <img src="{{ 'spice-editorial-workbench.jpg' | asset_url }}" width="1600" height="1000" loading="lazy" alt="Gewürzmanufaktur mit Bio-Gewürzen">
    </div>
    <div>
      <p class="sf-eyebrow">Manufaktur und Sortiment</p>
      <h2 class="sf-heading sf-heading--medium">Gewürze, die nach Gericht und Aroma verständlich werden.</h2>
      <p class="sf-copy">
        Gute Gewürze verkaufen sich über Anwendung: Wofür passt es, welche Größe ist sinnvoll,
        welche Kombination macht das Gericht rund und wann lohnt sich ein Set?
      </p>
      <div class="sf-feature-list">
        <div class="sf-feature-item" style="--dot:var(--sf-clay)"><div><h3>Dose, Refill oder Vorrat</h3><p>Wähle die Größe, die zu deiner Küche passt.</p></div></div>
        <div class="sf-feature-item" style="--dot:var(--sf-sage)"><div><h3>Nach Anlass finden</h3><p>Grillen, Dip, Brunch, Gemüse oder Geschenk führen direkt zur passenden Mischung.</p></div></div>
        <div class="sf-feature-item" style="--dot:var(--sf-berry)"><div><h3>Rezepte mit Würze</h3><p>Gerichte, Sets und Empfehlungen greifen natürlich ineinander.</p></div></div>
      </div>
    </div>
  </div>
</section>

<section class="sf-section sf-b2b-band" id="gifts">
  <div class="sf-page">
    <div class="sf-section-intro">
      <div>
        <p class="sf-eyebrow">Geschenke und Vorrat</p>
        <h2 class="sf-heading sf-heading--medium">Sets für Menschen, die gern gut kochen.</h2>
      </div>
      <a class="sf-button sf-button--ghost" href="{{ set_collection_url }}">Alle Sets ansehen</a>
    </div>
    <div class="sf-grid sf-grid--2">
      {% if set_collection.products.size > 0 %}
        {% for product in set_collection.products limit: 2 %}
          {% render 'product-card-spice', product: product %}
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

<section class="sf-section full-width" id="b2b">
  <div class="sf-page sf-b2b-panel">
    <div>
      <p class="sf-eyebrow" style="color:#d9e6c4">B2B</p>
      <h2 class="sf-heading sf-heading--medium">Firmengeschenke, Private Label und Wiederverkäufer sauber führen.</h2>
      <p class="sf-copy">
        Für Teams, Kundengeschenke und Wiederverkäufer: Muster, Mindestmengen,
        Personalisierung und Lieferzeit lassen sich direkt anfragen.
      </p>
    </div>
    <a class="sf-button sf-button--light" href="{{ routes.root_url }}">Anfrage vorbereiten</a>
  </div>
</section>

<script>
  (() => {
    document.querySelectorAll('[data-finder]').forEach((finder) => {
      const choices = Array.from(finder.querySelectorAll('[data-finder-target]'));
      const results = Array.from(finder.querySelectorAll('[data-finder-result]'));
      choices.forEach((choice) => {
        choice.addEventListener('click', () => {
          const target = choice.dataset.finderTarget;
          choices.forEach((item) => {
            const active = item === choice;
            item.classList.toggle('is-active', active);
            item.setAttribute('aria-selected', active ? 'true' : 'false');
          });
          results.forEach((result) => {
            const active = result.dataset.finderResult === target;
            result.hidden = !active;
            result.classList.toggle('is-active', active);
          });
        });
      });
    });

    document.querySelectorAll('[data-bundle-add]').forEach((button) => {
      button.addEventListener('click', async () => {
        const note = button.parentElement.querySelector('[data-bundle-note]');
        const originalText = button.textContent;
        button.disabled = true;
        button.textContent = 'Wird hinzugefügt ...';
        try {
          const items = JSON.parse(button.dataset.items || '[]');
          const response = await fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify({ items }),
          });
          if (!response.ok) throw new Error('Cart add failed');
          button.textContent = 'Im Warenkorb';
          if (note) note.textContent = 'Rezeptkorb hinzugefügt. Du wirst zum Warenkorb weitergeleitet.';
          window.setTimeout(() => { window.location.href = '/cart'; }, 650);
        } catch (error) {
          button.disabled = false;
          button.textContent = originalText;
          if (note) note.textContent = 'Der Rezeptkorb konnte nicht hinzugefügt werden. Bitte Produkte einzeln wählen.';
        }
      });
    });
  })();
</script>

