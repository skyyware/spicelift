{% assign spice_collection = collections['gewuerzmischungen'] %}
{% assign set_collection = collections['gewuerzsets'] %}
{% assign brunch_collection = collections['brunch-fruehstueck'] %}
{% assign grill_collection = collections['grillen-sommer'] %}
{% assign dip_collection = collections['dips-saucen'] %}
{% assign refill_collection = collections['nachfuellpacks-vorrat'] %}
{% assign spice_collection_url = routes.collections_url | append: '/gewuerzmischungen' %}
{% assign b2b_page = pages['b2b-corporate-gifts'] %}
{% assign recipes_page = pages['recipes'] %}
{% assign gift_finder_page = pages['gift-finder'] %}
{% assign b2b_url = routes.root_url | append: '#b2b' %}
{% assign recipes_url = routes.root_url | append: '#recipe-to-cart' %}
{% assign gift_finder_url = routes.root_url | append: '#gifts' %}
{% if b2b_page != blank %}
  {% assign b2b_url = b2b_page.url %}
{% endif %}
{% if recipes_page != blank %}
  {% assign recipes_url = recipes_page.url %}
{% endif %}
{% if gift_finder_page != blank %}
  {% assign gift_finder_url = gift_finder_page.url %}
{% endif %}
{% assign use_case_handles = 'brunch,grill,alltag,geschenk' | split: ',' %}
{% assign has_use_cases = false %}
{% assign featured_recipe = shop.metaobjects.spicelift_recipe['knusprige-bagel-bowl'] %}
{% assign bagel = all_products['bio-bagel-gewuerz'] %}
{% assign avocado = all_products['bio-avocado-gewuerz'] %}
{% assign cafe = all_products['bio-cafe-de-paris-gewuerz'] %}
{% assign bruehe = all_products['bio-gemuesebruehe'] %}
{% assign grill_set = all_products['bio-grillabend-set'] %}
{% assign brunch_set = all_products['bio-brunch-bagel-set'] %}

<section class="sf-hero full-width">
  <img
    class="sf-hero__image"
    src="{{ 'spice-hero-premium.jpg' | asset_url }}"
    width="2000"
    height="1400"
    loading="eager"
    fetchpriority="high"
    alt=""
  >
  <div class="sf-page sf-hero__inner">
    <p class="sf-eyebrow">Bio Gewürze aus der Manufaktur</p>
    <h1 class="sf-heading">Bio-Gewürze für klare Küche.</h1>
    <p class="sf-copy">
      Intensive Bio-Gewürze, kuratierte Sets und einfache Rezeptideen für Küche,
      Geschenk und Vorrat. Klar in der Auswahl, hochwertig im Geschmack.
    </p>
    <div class="sf-hero__actions">
      <a class="sf-button" href="{{ spice_collection_url }}">Gewürze entdecken</a>
      <a class="sf-button sf-button--on-dark" href="{{ recipes_url }}">Rezepte ansehen</a>
    </div>
    <div class="sf-hero__proof" aria-label="Spicelift Vorteile">
      <div class="sf-proof-item"><strong>100% Bio</strong><span>Ausgewählte Rohstoffe und klare Zutaten.</span></div>
      <div class="sf-proof-item"><strong>4,94 / 5</strong><span>Vertrauen direkt vor der Kaufentscheidung.</span></div>
      <div class="sf-proof-item"><strong>Ab 40 €</strong><span>Versandkostenfrei in Deutschland.</span></div>
    </div>
  </div>
</section>

<section class="sf-category-strip full-width" aria-label="Kategorien">
  <div class="sf-page sf-category-list">
    <a class="sf-category-card" href="{{ spice_collection_url }}">
      <span class="sf-category-card__image"><img src="{{ 'spice-product-bio-bagel-gewuerz.jpg' | asset_url }}" alt="" width="144" height="144" loading="lazy"></span>
      <strong>Gewürzmischungen<span>Für Alltag, Grillen, Dips und Bowls</span></strong>
    </a>
    <a class="sf-category-card" href="{{ gift_finder_url }}">
      <span class="sf-category-card__image"><img src="{{ 'spice-product-bio-grillabend-set.jpg' | asset_url }}" alt="" width="144" height="144" loading="lazy"></span>
      <strong>Geschenksets<span>Für Küche, Kundschaft und Gastgeber</span></strong>
    </a>
    <a class="sf-category-card" href="{% if brunch_collection != blank %}{{ brunch_collection.url }}{% else %}#recipe-to-cart{% endif %}">
      <span class="sf-category-card__image"><img src="{{ 'spice-product-bio-avocado-gewuerz.jpg' | asset_url }}" alt="" width="144" height="144" loading="lazy"></span>
      <strong>Brunch<span>Vom Anlass direkt zum Warenkorb</span></strong>
    </a>
    <a class="sf-category-card" href="{{ b2b_url }}">
      <span class="sf-category-card__image"><img src="{{ 'spice-product-bio-brunch-bagel-set.jpg' | asset_url }}" alt="" width="144" height="144" loading="lazy"></span>
      <strong>Business<span>Firmengeschenke und White Label</span></strong>
    </a>
  </div>
</section>

<section class="sf-section sf-finder-section full-width" id="aroma-finder">
  <div class="sf-page sf-finder">
    <div class="sf-finder__copy">
      <p class="sf-eyebrow">Aroma-Finder</p>
      <h2 class="sf-heading sf-heading--medium">Nicht suchen. Passend würzen.</h2>
      <p class="sf-copy">
        Der schnellste Weg zum richtigen Produkt ist nicht die Produktliste, sondern der Kochanlass.
        Wenige Anlässe, klare Empfehlungen und direkt passende Größen.
      </p>
      <div class="sf-finder__metrics" aria-label="Commerce-Hebel">
        <span><strong>1</strong> Anlass</span>
        <span><strong>2</strong> Empfehlungen</span>
      </div>
    </div>

    {% if has_use_cases %}
      <div class="sf-finder__panel" data-finder>
        <div class="sf-finder__choices" role="tablist" aria-label="Kochanlass auswählen">
          {% assign active_assigned = false %}
          {% for use_case_handle in use_case_handles %}
            {% assign use_case = shop.metaobjects.spicelift_use_case[use_case_handle] %}
            {% if use_case != blank %}
              {% assign is_active = false %}
              {% unless active_assigned %}
                {% assign is_active = true %}
                {% assign active_assigned = true %}
              {% endunless %}
              <button
                class="sf-finder-choice{% if is_active %} is-active{% endif %}"
                type="button"
                role="tab"
                aria-selected="{% if is_active %}true{% else %}false{% endif %}"
                data-finder-target="{{ use_case_handle }}"
              >
                <span>{{ use_case.title.value }}</span>
                <small>{{ use_case.subtitle.value }}</small>
              </button>
            {% endif %}
          {% endfor %}
        </div>

        <div class="sf-finder-results">
          {% assign active_assigned = false %}
          {% for use_case_handle in use_case_handles %}
            {% assign use_case = shop.metaobjects.spicelift_use_case[use_case_handle] %}
            {% if use_case != blank %}
              {% assign is_active = false %}
              {% assign use_case_heading = use_case.heading.value %}
              {% assign use_case_summary = use_case.summary.value %}
              {% unless active_assigned %}
                {% assign is_active = true %}
                {% assign active_assigned = true %}
              {% endunless %}
              {% if use_case_handle == 'brunch' %}
                {% assign use_case_heading = 'Brunch ohne Auswahlstress.' %}
                {% assign use_case_summary = 'Bagel-Gewürz bringt Crunch, Avocado-Gewürz Kräuter, Chili und Zitrusfrische für Bagel, Ei, Dip und Bowl.' %}
              {% endif %}
              {% assign case_products = use_case.products.value %}
              {% assign case_collection = use_case.collection.value %}
              <div class="sf-finder-result{% if is_active %} is-active{% endif %}" data-finder-result="{{ use_case_handle }}"{% unless is_active %} hidden{% endunless %}>
                <div class="sf-finder-result__copy">
                  <p class="sf-eyebrow">Empfehlung · {{ use_case.metric.value }}</p>
                  <h3>{{ use_case_heading }}</h3>
                  <p>{{ use_case_summary }}</p>
                  {% if case_collection != blank %}
                    <a class="sf-inline-link" href="{{ case_collection.url }}">Auswahl ansehen</a>
                  {% endif %}
                </div>
                <div class="sf-finder-products">
                  {% for case_product in case_products limit: 2 %}
                    {% render 'product-card-spice', product: case_product, compact: true %}
                  {% endfor %}
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    {% else %}
      <div class="sf-finder__panel" data-finder>
        <div class="sf-finder__choices" role="tablist" aria-label="Kochanlass auswählen">
          <button class="sf-finder-choice is-active" type="button" role="tab" aria-selected="true" data-finder-target="brunch">
            <span>Brunch</span>
            <small>Bagel, Avocado, Ei</small>
          </button>
          <button class="sf-finder-choice" type="button" role="tab" aria-selected="false" data-finder-target="grill">
            <span>Grillen</span>
            <small>Gemüse, Dip, Butter</small>
          </button>
          <button class="sf-finder-choice" type="button" role="tab" aria-selected="false" data-finder-target="alltag">
            <span>Alltag</span>
            <small>Suppe, Risotto, Meal Prep</small>
          </button>
          <button class="sf-finder-choice" type="button" role="tab" aria-selected="false" data-finder-target="geschenk">
            <span>Geschenk</span>
            <small>Kuratierte Sets</small>
          </button>
        </div>

        <div class="sf-finder-results">
          <div class="sf-finder-result is-active" data-finder-result="brunch">
            <div class="sf-finder-result__copy">
              <p class="sf-eyebrow">Empfehlung</p>
              <h3>Brunch ohne Auswahlstress.</h3>
              <p>Bagel-Gewürz bringt Crunch, Avocado-Gewürz Kräuter, Chili und Zitrusfrische für Bagel, Ei, Dip und Bowl.</p>
            </div>
            <div class="sf-finder-products">
              {% if bagel != blank %}{% render 'product-card-spice', product: bagel, compact: true %}{% endif %}
              {% if avocado != blank %}{% render 'product-card-spice', product: avocado, compact: true %}{% endif %}
            </div>
          </div>

          <div class="sf-finder-result" data-finder-result="grill" hidden>
            <div class="sf-finder-result__copy">
              <p class="sf-eyebrow">Empfehlung</p>
              <h3>Grillen mit Plan.</h3>
              <p>Café de Paris für Kräuterbutter, Grillabend-Set für Gemüse, Dip und Marinade.</p>
            </div>
            <div class="sf-finder-products">
              {% if cafe != blank %}{% render 'product-card-spice', product: cafe, compact: true %}{% endif %}
              {% if grill_set != blank %}{% render 'product-card-spice', product: grill_set, compact: true %}{% endif %}
            </div>
          </div>

          <div class="sf-finder-result" data-finder-result="alltag" hidden>
            <div class="sf-finder-result__copy">
              <p class="sf-eyebrow">Empfehlung</p>
              <h3>Alltag sauber gelöst.</h3>
              <p>Gemüsebrühe als Basis, Avocado-Gewürz als frisches Finish für schnelle Küche.</p>
            </div>
            <div class="sf-finder-products">
              {% if bruehe != blank %}{% render 'product-card-spice', product: bruehe, compact: true %}{% endif %}
              {% if avocado != blank %}{% render 'product-card-spice', product: avocado, compact: true %}{% endif %}
            </div>
          </div>

          <div class="sf-finder-result" data-finder-result="geschenk" hidden>
            <div class="sf-finder-result__copy">
              <p class="sf-eyebrow">Empfehlung</p>
              <h3>Geschenke ohne Rätselraten.</h3>
              <p>Kuratierte Sets für Gastgeber, Kundschaft und saisonale Anlässe.</p>
            </div>
            <div class="sf-finder-products">
              {% if brunch_set != blank %}{% render 'product-card-spice', product: brunch_set, compact: true %}{% endif %}
              {% if grill_set != blank %}{% render 'product-card-spice', product: grill_set, compact: true %}{% endif %}
            </div>
          </div>
        </div>
      </div>
    {% endif %}
  </div>
</section>

<section class="sf-section" id="favorites">
  <div class="sf-page">
    <div class="sf-section-intro">
      <div>
        <p class="sf-eyebrow">Beliebt in der Küche</p>
        <h2 class="sf-heading sf-heading--medium">Schneller vom Kochanlass zum richtigen Aroma.</h2>
      </div>
      <div class="sf-chip-row" aria-label="Kochanlässe">
        <a class="sf-chip" href="{% if grill_collection != blank %}{{ grill_collection.url }}{% else %}{{ spice_collection_url }}{% endif %}">Zum Grillen</a>
        <a class="sf-chip" href="{% if dip_collection != blank %}{{ dip_collection.url }}{% else %}{{ spice_collection_url }}{% endif %}">Für Dips</a>
      <a class="sf-chip" href="{% if refill_collection != blank %}{{ refill_collection.url }}{% else %}{{ spice_collection_url }}{% endif %}">Nachfüllpacks</a>
        <a class="sf-chip" href="{{ gift_finder_url }}">Als Geschenk</a>
      </div>
    </div>

    <div class="sf-grid sf-grid--4">
      {% if spice_collection.products.size > 0 %}
        {% for product in spice_collection.products limit: 4 %}
          {% render 'product-card-spice', product: product %}
        {% endfor %}
      {% else %}
        <p>Produkte werden bald angezeigt.</p>
      {% endif %}
    </div>
  </div>
</section>

<section class="sf-section sf-usecase full-width" id="recipe-to-cart">
  {% assign recipe_products = blank %}
  {% assign recipe_steps = blank %}
  {% if featured_recipe != blank %}
    {% assign recipe_products = featured_recipe.products.value %}
    {% assign recipe_steps = featured_recipe.steps.value %}
  {% endif %}
  <div class="sf-page sf-usecase-grid">
    <div class="sf-recipe-card">
      <p class="sf-eyebrow">{% if featured_recipe != blank %}{{ featured_recipe.occasion.value }}{% else %}Rezept des Tages{% endif %}</p>
      <h2>{% if featured_recipe != blank %}{{ featured_recipe.title.value }}{% else %}Knusprige Bagel Bowl mit Avocado-Dip.{% endif %}</h2>
      <p class="sf-copy">{% if featured_recipe != blank %}{{ featured_recipe.summary.value }}{% else %}Ein schneller Brunch-Favorit mit zwei Gewürzen, die Bagel, Avocado und Dip zusammenbringen.{% endif %}</p>
    </div>

    <div class="sf-recipe-stack">
      {% if recipe_steps != blank %}
        {% for step in recipe_steps %}
          {% assign step_heading = step | split: ':' | first | strip %}
          {% assign step_copy = step | split: ':' | last | strip %}
          {% if forloop.index == 1 %}
            {% assign step_heading = 'Brunch-Basis anrichten' %}
            {% assign step_copy = 'Bagel rösten, Dip aufschlagen, Avocado und Ei als klare Basis vorbereiten.' %}
          {% elsif forloop.index == 2 %}
            {% assign step_heading = 'Mit Crunch und Frische finalisieren' %}
            {% assign step_copy = 'Bagel-Gewürz bringt Sesam und Zwiebel, Avocado-Gewürz Kräuter, Zitrus und milde Schärfe.' %}
          {% else %}
            {% assign step_heading = step_heading | remove: '01 ' | remove: '02 ' | remove: '03 ' | remove: '04 ' %}
          {% endif %}
          <div class="sf-recipe-step{% if forloop.first %} is-current{% endif %}">
            <span class="sf-recipe-step__index">{% if forloop.index < 10 %}0{% endif %}{{ forloop.index }}</span>
            <div>
              <h3>{{ step_heading }}</h3>
              <p>{{ step_copy }}</p>
            </div>
          </div>
        {% endfor %}
      {% else %}
        <div class="sf-recipe-step is-current">
          <span class="sf-recipe-step__index">01</span>
          <div>
            <h3>Brunch-Basis anrichten</h3>
            <p>Bagel rösten, Dip aufschlagen, Avocado und Ei als klare Basis vorbereiten.</p>
          </div>
        </div>
        <div class="sf-recipe-step">
          <span class="sf-recipe-step__index">02</span>
          <div>
            <h3>Mit Crunch und Frische finalisieren</h3>
            <p>Sesam, Zwiebel, Kräuter und Zitrus bringen Brunch, Dip und Bowl sauber zusammen.</p>
          </div>
        </div>
      {% endif %}
      <div class="sf-grid sf-grid--2">
        {% if recipe_products != blank %}
          {% for recipe_product in recipe_products limit: 2 %}
            {% render 'product-card-spice', product: recipe_product %}
          {% endfor %}
        {% else %}
          {% if bagel != blank %}{% render 'product-card-spice', product: bagel %}{% endif %}
          {% if avocado != blank %}{% render 'product-card-spice', product: avocado %}{% endif %}
        {% endif %}
      </div>
      {% if recipe_products != blank %}
        {% capture recipe_items_json %}
          [
            {% for recipe_product in recipe_products %}
              {"id":{{ recipe_product.selected_or_first_available_variant.id | json }},"quantity":1}{% unless forloop.last %},{% endunless %}
            {% endfor %}
          ]
        {% endcapture %}
        <button
          class="sf-button sf-bundle-button"
          type="button"
          data-bundle-add
          data-items='{{ recipe_items_json | strip_newlines | strip }}'
        >
          {{ featured_recipe.cta_label.value | default: 'Rezeptkorb hinzufügen' }}
        </button>
      {% elsif bagel != blank and avocado != blank %}
        <button
          class="sf-button sf-bundle-button"
          type="button"
          data-bundle-add
          data-items='[{"id":{{ bagel.selected_or_first_available_variant.id | json }},"quantity":1},{"id":{{ avocado.selected_or_first_available_variant.id | json }},"quantity":1}]'
        >
          Rezeptkorb hinzufügen
        </button>
      {% endif %}
    </div>
  </div>
</section>

<section class="sf-section sf-editorial full-width" id="manufaktur">
  <div class="sf-page sf-editorial-grid">
    <div class="sf-editorial-image">
      <img src="{{ 'spice-editorial-workbench.jpg' | asset_url }}" width="1600" height="1000" loading="lazy" alt="Gewürzmanufaktur mit Bio-Gewürzen">
    </div>
    <div>
      <p class="sf-eyebrow">Manufaktur und Sortiment</p>
      <h2 class="sf-heading sf-heading--medium">Gewürze, die nach Gericht und Aroma verständlich werden.</h2>
      <p class="sf-copy">
        Gute Gewürze verkaufen sich über Anwendung: Wofür passt es, welche Größe ist sinnvoll,
        welche Kombination macht das Gericht rund und wann lohnt sich ein Set?
      </p>
      <div class="sf-feature-list">
        <div class="sf-feature-item" style="--dot:var(--sf-clay)"><div><h3>Dose, Refill oder Vorrat</h3><p>Wähle die Größe, die zu deiner Küche passt.</p></div></div>
        <div class="sf-feature-item" style="--dot:var(--sf-sage)"><div><h3>Nach Anlass finden</h3><p>Grillen, Dip, Brunch, Gemüse oder Geschenk führen direkt zur passenden Mischung.</p></div></div>
        <div class="sf-feature-item" style="--dot:var(--sf-berry)"><div><h3>Rezepte mit Würze</h3><p>Gerichte, Sets und Empfehlungen greifen natürlich ineinander.</p></div></div>
      </div>
    </div>
  </div>
</section>

<section class="sf-section sf-b2b-band full-width" id="gifts">
  <div class="sf-page">
    <div class="sf-section-intro">
      <div>
        <p class="sf-eyebrow">Geschenke und Vorrat</p>
        <h2 class="sf-heading sf-heading--medium">Für Menschen, die gern kochen.</h2>
      </div>
      <a class="sf-button sf-button--ghost" href="{{ gift_finder_url }}">Geschenkfinder öffnen</a>
    </div>
    <div class="sf-grid sf-grid--2">
      {% if set_collection.products.size > 0 %}
        {% for product in set_collection.products limit: 2 %}
          {% render 'product-card-spice', product: product %}
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

<section class="sf-section full-width" id="b2b">
  <div class="sf-page sf-b2b-panel">
    <div>
      <p class="sf-eyebrow" style="color:#d9e6c4">B2B</p>
      <h2 class="sf-heading sf-heading--medium">White Label.</h2>
      <p class="sf-copy">
        Für Teams, Kundengeschenke und Wiederverkauf: Mengen, Etiketten,
        Liefertermine und Nachbestellung werden vor der Anfrage klar.
      </p>
    </div>
    <a class="sf-button sf-button--light" href="{{ b2b_url }}">Anfragen</a>
  </div>
</section>

{% schema %}
{
  "name": "Spicelift Home",
  "settings": [],
  "presets": [
    {
      "name": "Spicelift Home"
    }
  ]
}
{% endschema %}
