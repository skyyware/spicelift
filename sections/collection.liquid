<section class="sf-collection-hero full-width">
  <div class="sf-page">
    <nav class="sf-breadcrumb sf-breadcrumb--hero" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">Start</a>
      <span aria-hidden="true">/</span>
      <span aria-current="page">{{ collection.title }}</span>
    </nav>
    <p class="sf-eyebrow">Kuratierte Auswahl</p>
    <h1 class="sf-heading sf-heading--medium">{{ collection.title }}</h1>
    <p class="sf-copy">
      {{ collection.description | strip_html | default: 'Finde Gewürze nach Kochanlass, Aroma und gewünschter Größe.' }}
    </p>
  </div>
</section>

<section class="sf-page sf-collection-paths" aria-label="Kaufpfade">
  <a class="sf-path-card" href="#ProductGrid" data-path-filter="all">
    <span>01</span>
    <strong>Erstkauf</strong>
    <small>Beliebte Dosen und Sets zum Kennenlernen.</small>
  </a>
  <a class="sf-path-card" href="#ProductGrid" data-path-filter="nachfullbar">
    <span>02</span>
    <strong>Refill</strong>
    <small>Nachfüllpack und Vorrat ohne erneute Suche.</small>
  </a>
  <a class="sf-path-card" href="#ProductGrid" data-path-filter="set">
    <span>03</span>
    <strong>Geschenk</strong>
    <small>Kuratierte Sets für Gastgeber und Kundschaft.</small>
  </a>
  <a class="sf-path-card" href="#ProductGrid" data-path-filter="grillen">
    <span>04</span>
    <strong>Anlass</strong>
    <small>Direkt von Gericht oder Saison zur passenden Würze.</small>
  </a>
</section>

<section class="sf-page sf-collection-grid">
  <aside class="sf-card sf-filter-panel" data-filter-panel>
    <p class="sf-eyebrow">Orientierung</p>
    <div class="sf-filter-group">
      <h3>Kochanlass</h3>
      <div class="sf-chip-row" id="ProductGrid">
        <button class="sf-chip sf-chip--button is-active" type="button" data-filter="all" aria-pressed="true">Alle</button>
        <button class="sf-chip sf-chip--button" type="button" data-filter="grillen" aria-pressed="false">Grillen</button>
        <button class="sf-chip sf-chip--button" type="button" data-filter="dip" aria-pressed="false">Dips & Saucen</button>
        <button class="sf-chip sf-chip--button" type="button" data-filter="brunch" aria-pressed="false">Brunch</button>
        <button class="sf-chip sf-chip--button" type="button" data-filter="gemuese" aria-pressed="false">Gemüse</button>
      </div>
    </div>
    <div class="sf-filter-group">
      <h3>Ernährung</h3>
      <div class="sf-chip-row">
        <button class="sf-chip sf-chip--button" type="button" data-filter="bio" aria-pressed="false">Bio</button>
        <button class="sf-chip sf-chip--button" type="button" data-filter="nachfullbar" aria-pressed="false">Nachfüllbar</button>
        <button class="sf-chip sf-chip--button" type="button" data-filter="set" aria-pressed="false">Sets</button>
      </div>
    </div>
    <div class="sf-filter-group">
      <h3>Aroma</h3>
      <div class="sf-chip-row">
        <span class="sf-chip">Kräutrig</span>
        <span class="sf-chip">Zitronig</span>
        <span class="sf-chip">Umami</span>
        <span class="sf-chip">Rauchig</span>
      </div>
    </div>
  </aside>

  <div>
    <div class="sf-section-intro" style="margin-bottom: 22px;">
      <p class="sf-copy" data-filter-summary>{{ collection.products_count }} Produkte für Küche, Geschenk und Vorrat.</p>
      <span class="sf-chip">Sortiert nach Bestseller</span>
    </div>

    {% paginate collection.products by 24 %}
      <div class="sf-products-grid" data-products-grid>
        {% for product in collection.products %}
          {% render 'product-card-spice', product: product %}
        {% endfor %}
      </div>
      <p class="sf-empty-filter" data-empty-filter hidden>Keine Produkte für diesen Filter in dieser Collection.</p>
      <div style="margin-top: 32px;">{{ paginate | default_pagination }}</div>
    {% endpaginate %}
  </div>
</section>

<script>
  (() => {
    const section = document.currentScript.closest('.shopify-section');
    if (!section) return;
    const buttons = Array.from(section.querySelectorAll('[data-filter]'));
    const cards = Array.from(section.querySelectorAll('[data-product-tags]'));
    const empty = section.querySelector('[data-empty-filter]');

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        const filter = button.dataset.filter;
        let visible = 0;
        buttons.forEach((item) => {
          const active = item === button;
          item.classList.toggle('is-active', active);
          item.setAttribute('aria-pressed', active ? 'true' : 'false');
        });
        cards.forEach((card) => {
          const match = filter === 'all' || card.dataset.productTags.includes(filter);
          card.hidden = !match;
          if (match) visible += 1;
        });
        if (empty) empty.hidden = visible > 0;
        const summary = section.querySelector('[data-filter-summary]');
        if (summary) {
          summary.textContent = filter === 'all'
            ? `${cards.length} Produkte für Küche, Geschenk und Vorrat.`
            : `${visible} passende Produkte in dieser Auswahl.`;
        }
      });
    });

    section.querySelectorAll('[data-path-filter]').forEach((link) => {
      link.addEventListener('click', () => {
        const filter = link.dataset.pathFilter;
        const button = section.querySelector(`[data-filter="${filter}"]`) || section.querySelector('[data-filter="all"]');
        if (button) button.click();
      });
    });
  })();
</script>

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Start",
        "item": {{ request.origin | append: routes.root_url | json }}
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": {{ collection.title | json }},
        "item": {{ request.origin | append: collection.url | json }}
      }
    ]
  }
</script>

{% schema %}
{
  "name": "t:general.collection",
  "settings": []
}
{% endschema %}
