{% assign accent = product.metafields.custom.accent_color.value | default: '#e85d36' %}
{% assign subtitle = product.metafields.custom.subtitle.value | default: product.type %}
{% assign usage = product.metafields.custom.usage.value | default: 'Bio Küche' %}
{% assign flavor = product.metafields.custom.flavor.value | default: 'Würzig, klar, vielseitig' %}
{% assign pairing = product.metafields.custom.pairing.value | default: 'Passt zu Gemüse, Dips und schnellen Feierabendgerichten.' %}
{% assign pairing_clean = pairing %}
{% if pairing contains 'Passt zu ' %}
  {% assign pairing_clean = pairing | remove_first: 'Passt zu ' %}
{% endif %}
{% assign product_asset = 'spice-product-' | append: product.handle | append: '.jpg' %}
{% assign current_variant = product.selected_or_first_available_variant %}
{% assign product_form_id = 'ProductForm-' | append: section.id %}
{% assign primary_collection = collections['gewuerzmischungen'] %}
{% assign refill_collection = collections['nachfuellpacks-vorrat'] %}
{% assign recipes_page = pages['recipes'] %}
{% assign gift_finder_page = pages['gift-finder'] %}
{% assign recipes_url = routes.root_url | append: '#recipe-to-cart' %}
{% assign gift_finder_url = routes.root_url | append: '#gifts' %}
{% if recipes_page != blank %}
  {% assign recipes_url = recipes_page.url %}
{% endif %}
{% if gift_finder_page != blank %}
  {% assign gift_finder_url = gift_finder_page.url %}
{% endif %}
{% if product.type contains 'Set' or product.tags contains 'set' %}
  {% assign primary_collection = collections['gewuerzsets'] %}
{% endif %}

<section class="sf-product-page" style="--spice-accent: {{ accent }}">
  <div class="sf-page">
    <nav class="sf-breadcrumb" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">Start</a>
      <span aria-hidden="true">/</span>
      {% if primary_collection != blank %}
        <a href="{{ primary_collection.url }}">{{ primary_collection.title }}</a>
      {% else %}
        <a href="{{ routes.collections_url }}">Sortiment</a>
      {% endif %}
      <span aria-hidden="true">/</span>
      <span aria-current="page">{{ product.title }}</span>
    </nav>

    <div class="sf-product-layout">
      <div class="sf-product-gallery">
        <div class="sf-product-main-image">
          <span class="sf-bio-badge">Bio</span>
          {% if product.featured_image %}
            {% render 'image',
              image: product.featured_image,
              width: 1100,
              height: 1100,
              crop: 'center',
              loading: 'eager',
              fetchpriority: 'high',
              sizes: '(min-width: 990px) 48vw, 100vw'
            %}
          {% else %}
            <img src="{{ product_asset | asset_url }}" width="1100" height="1100" loading="eager" alt="{{ product.title | escape }}">
          {% endif %}
        </div>
        <div class="sf-product-thumbs" aria-label="Produktvorteile">
          <div class="sf-product-thumb"><strong>Aroma</strong><br>{{ flavor }}</div>
          <div class="sf-product-thumb"><strong>Anwendung</strong><br>{{ pairing_clean | truncate: 84 }}</div>
          <div class="sf-product-thumb"><strong>Kaufpfad</strong><br>Dose, Refill und Vorratsgröße.</div>
        </div>
      </div>

      <div class="sf-product-summary" id="ProductInfo-{{ section.id }}">
        <p class="sf-eyebrow">{{ usage }}</p>
        <h1>{{ product.title }}</h1>
        <p class="sf-copy">{{ subtitle }}</p>
        <div class="sf-product-kicker">
          <span class="sf-chip">{{ flavor }}</span>
          <span class="sf-chip">100% Bio</span>
          <span class="sf-chip">Ohne Zusätze</span>
        </div>
        <p class="sf-rating">★★★★★ <span style="color:var(--sf-muted);">4,94 / 5 aus Kundenbewertungen</span></p>

        <div class="sf-product-decision-panel" aria-label="Produktentscheidung">
          <div>
            <span>Geschmack</span>
            <strong>{{ flavor }}</strong>
          </div>
          <div>
            <span>Passt zu</span>
            <strong>{{ pairing_clean }}</strong>
          </div>
          <div>
            <span>Kaufpfad</span>
            <strong>Dose zum Start, Refill für Wiederkauf, Vorrat für Teams und Vielkocher.</strong>
          </div>
        </div>

        <div>
          <p class="sf-eyebrow">Wähle deine Größe</p>
          {% form 'product', product, id: product_form_id, class: 'sf-product-form' %}
            <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-input>
            <div class="sf-variant-grid" role="list">
              {% for variant in product.variants %}
                {% assign variant_label = 'Zum Kennenlernen' %}
                {% assign variant_hint = 'Für den ersten Kauf und die schnelle Küche.' %}
                {% assign variant_title_downcase = variant.title | downcase %}
                {% if variant_title_downcase contains 'nachfüll' or variant_title_downcase contains '250' or variant_title_downcase contains '500' %}
                  {% assign variant_label = 'Beste Wahl' %}
                  {% assign variant_hint = 'Für Wiederkauf, Vorrat und weniger Verpackungswechsel.' %}
                {% endif %}
                {% if variant_title_downcase contains 'gastro' or variant_title_downcase contains '1kg' or variant_title_downcase contains 'vorrat' %}
                  {% assign variant_label = 'Vorrat' %}
                  {% assign variant_hint = 'Für Vielkocher, Teams und B2B-Anwendungen.' %}
                {% endif %}
                {% if product.type contains 'Set' or product.title contains 'Set' %}
                  {% assign variant_label = 'Geschenkpfad' %}
                  {% assign variant_hint = 'Für Gastgeber, Kundengeschenke und kuratierte Anlässe.' %}
                {% endif %}
                <button
                  class="sf-variant-card"
                  type="button"
                  data-variant-id="{{ variant.id }}"
                  data-price="{{ variant.price | money_without_trailing_zeros }}"
                  aria-pressed="{% if variant == current_variant %}true{% else %}false{% endif %}"
                >
                  <span class="sf-variant-dot"></span>
                  <span>
                    <strong>{{ variant.title }}</strong>
                    <small>{{ variant_label }} · {{ variant_hint }}</small>
                  </span>
                  <strong>{{ variant.price | money_without_trailing_zeros }}</strong>
                </button>
              {% endfor %}
            </div>

            <p class="sf-price" data-product-price>{{ current_variant.price | money_without_trailing_zeros }}</p>
            {% if current_variant.sku != blank %}
              <p class="sf-product-sku">Artikelnummer {{ current_variant.sku }}</p>
            {% endif %}
            <div class="sf-buy-guidance" aria-label="Kaufhinweise">
              <span>Lieferung in 2-4 Werktagen</span>
              <span>Sichere Zahlung im Shopify Checkout</span>
              <span>Nachfüllpack und Vorratsgröße auswählbar</span>
            </div>
            <div class="sf-quantity">
              <label for="Quantity-{{ section.id }}">Anzahl</label>
              <input id="Quantity-{{ section.id }}" type="number" name="quantity" min="1" value="1">
            </div>

            <button class="sf-button" type="submit">In den Warenkorb</button>
          {% endform %}
        </div>

        <div class="sf-trust-grid">
          <div class="sf-trust-card"><strong>Ab 40 €</strong>Versandkostenfrei in Deutschland.</div>
          <div class="sf-trust-card"><strong>Schnelle Küche</strong>Ein Gewürz, viele Gerichte.</div>
          <div class="sf-trust-card"><strong>Refill-Logik</strong>Wiederkauf ohne Suchweg.</div>
        </div>
      </div>
    </div>

    <section class="sf-refill-advisor" aria-labelledby="refill-advisor-heading">
      <div class="sf-refill-advisor__intro">
        <p class="sf-eyebrow">Kaufpfad-Kompass</p>
        <h2 id="refill-advisor-heading">Dose, Refill oder Vorrat?</h2>
      </div>
      <div class="sf-refill-advisor__grid">
        <article>
          <span>Erstkauf</span>
          <strong>Dose wählen</strong>
          <p>Für Kennenlernen, Geschenkfähigkeit und klare Dosierung in der Küche.</p>
        </article>
        <article>
          <span>Wiederkauf</span>
          <strong>Refill wählen</strong>
          <p>Wenn die Dose vorhanden ist und weniger Verpackungswechsel gewünscht ist.</p>
        </article>
        <article>
          <span>Vorrat</span>
          <strong>Großpackung wählen</strong>
          <p>Für Teams, Gastro, Vielkocher und wiederkehrende Produktion.</p>
        </article>
      </div>
      <div class="sf-refill-advisor__actions">
        {% if refill_collection != blank %}
          <a class="sf-inline-link" href="{{ refill_collection.url }}">Nachfüll- und Vorratspfad ansehen</a>
        {% endif %}
        <a class="sf-inline-link" href="{{ recipes_url }}">Rezeptideen zum Produkt</a>
        <a class="sf-inline-link" href="{{ gift_finder_url }}">Als Geschenk einordnen</a>
      </div>
    </section>

    <section class="sf-pdp-blueprint" aria-labelledby="pdp-blueprint-heading">
      <div>
        <p class="sf-eyebrow">Kaufentscheidung</p>
        <h2 id="pdp-blueprint-heading" class="sf-heading sf-heading--medium">Jedes Produkt beantwortet drei Fragen.</h2>
      </div>
      <div class="sf-blueprint-steps">
        <article>
          <span>01</span>
          <h3>Wofür passt es?</h3>
          <p>{{ pairing }}</p>
        </article>
        <article>
          <span>02</span>
          <h3>Welche Größe ist sinnvoll?</h3>
          <p>Dose für Einstieg, Refill für Wiederkauf, Vorrat für Vielkocher und Teams.</p>
        </article>
        <article>
          <span>03</span>
          <h3>Was ergänzt es?</h3>
          <p>Passende Sets und Pairings erhöhen Warenkorbwert, ohne künstlich zu wirken.</p>
        </article>
      </div>
    </section>

    <div class="sf-story">
      <div class="sf-story-card">
        <p class="sf-eyebrow">Geschmack</p>
        <h3>{{ flavor }}</h3>
        <p>Ein klarer Geschmack, der beim Kochen sofort Orientierung gibt.</p>
      </div>
      <div class="sf-story-card">
        <p class="sf-eyebrow">Anwendung</p>
        <h3>Passt zu</h3>
        <p>{{ pairing_clean }}</p>
      </div>
      <div class="sf-story-card">
        <p class="sf-eyebrow">Empfehlung</p>
        <h3>Mehr aus dem Produkt machen</h3>
        <p>Kombiniere Dose und Nachfüllpack oder wähle ein Set für mehrere Kochanlässe.</p>
      </div>
    </div>

    {% assign related_collection = collections['gewuerzmischungen'] %}
    {% if product.type == 'Gewürzmischung' %}
      {% assign related_collection = collections['gewuerzsets'] %}
    {% endif %}
    {% if related_collection.products.size > 0 %}
      <section class="sf-related-products">
        <div class="sf-section-intro">
          <div>
            <p class="sf-eyebrow">Passt dazu</p>
            <h2 class="sf-heading sf-heading--medium">Mehr aus dem Gericht machen.</h2>
          </div>
          <a class="sf-button sf-button--ghost" href="{{ related_collection.url }}">Alle ansehen</a>
        </div>
        <div class="sf-grid sf-grid--3">
          {% assign shown = 0 %}
          {% for related_product in related_collection.products %}
            {% unless related_product.id == product.id %}
              {% render 'product-card-spice', product: related_product %}
              {% assign shown = shown | plus: 1 %}
            {% endunless %}
            {% if shown >= 3 %}{% break %}{% endif %}
          {% endfor %}
        </div>
      </section>
    {% endif %}
  </div>

  <div class="sf-mobile-buy" aria-label="Mobiler Kaufbereich">
    <div>
      <strong>{{ product.title }}</strong><br>
      <span data-mobile-product-price>{{ current_variant.price | money_without_trailing_zeros }}</span>
    </div>
    <button class="sf-button" type="submit" form="{{ product_form_id }}">In den Warenkorb</button>
  </div>
</section>

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Start",
        "item": {{ request.origin | append: routes.root_url | json }}
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": {% if primary_collection != blank %}{{ primary_collection.title | json }}{% else %}"Sortiment"{% endif %},
        "item": {% if primary_collection != blank %}{{ request.origin | append: primary_collection.url | json }}{% else %}{{ request.origin | append: routes.collections_url | json }}{% endif %}
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": {{ product.title | json }},
        "item": {{ request.origin | append: product.url | json }}
      }
    ]
  }
</script>

<script>
  (() => {
    const root = document.currentScript.closest('.shopify-section');
    if (!root) return;
    const hidden = root.querySelector('[data-variant-input]');
    const price = root.querySelector('[data-product-price]');
    const mobilePrice = root.querySelector('[data-mobile-product-price]');
    const mobileBuy = root.querySelector('.sf-mobile-buy');
    root.querySelectorAll('[data-variant-id]').forEach((button) => {
      button.addEventListener('click', () => {
        root.querySelectorAll('[data-variant-id]').forEach((item) => item.setAttribute('aria-pressed', 'false'));
        button.setAttribute('aria-pressed', 'true');
        hidden.value = button.dataset.variantId;
        price.textContent = button.dataset.price;
        if (mobilePrice) mobilePrice.textContent = button.dataset.price;
      });
    });

    if (mobileBuy) {
      const toggleMobileBuy = () => {
        mobileBuy.classList.toggle('is-visible', window.scrollY > 720);
      };
      window.addEventListener('scroll', toggleMobileBuy, { passive: true });
      toggleMobileBuy();
    }
  })();
</script>

{% schema %}
{
  "name": "t:general.product",
  "settings": [],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
