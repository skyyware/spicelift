<div class="sf-topbar full-width">
  <div class="sf-page sf-topbar__inner">
    <span>Bio Gewürze aus der Manufaktur</span>
    <span class="sf-topbar__rating">★★★★★ 4,94 von 5</span>
    <span class="sf-topbar__right">Ab 40 € versandkostenfrei in Deutschland</span>
  </div>
</div>

{% assign spice_collection_url = routes.collections_url | append: '/gewuerzmischungen' %}
{% assign set_collection_url = routes.collections_url | append: '/gewuerzsets' %}
{% assign b2b_page = pages['b2b-corporate-gifts'] %}
{% assign recipes_page = pages['recipes'] %}
{% assign gift_finder_page = pages['gift-finder'] %}
{% assign b2b_url = routes.root_url | append: '#b2b' %}
{% assign recipes_url = routes.root_url | append: '#recipe-to-cart' %}
{% assign gift_finder_url = routes.root_url | append: '#gifts' %}
{% if b2b_page != blank %}
  {% assign b2b_url = b2b_page.url %}
{% endif %}
{% if recipes_page != blank %}
  {% assign recipes_url = recipes_page.url %}
{% endif %}
{% if gift_finder_page != blank %}
  {% assign gift_finder_url = gift_finder_page.url %}
{% endif %}

<header class="sf-header full-width">
  <div class="sf-page sf-header__inner">
    <a class="sf-logo" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
      <span class="sf-logo__mark" aria-hidden="true">S</span>
      <span class="sf-logo__text">
        <span class="sf-logo__wordmark">SPICELIFT</span>
        <span class="sf-logo__tagline">Bio Gewürzmanufaktur</span>
      </span>
    </a>

    <nav class="sf-nav" aria-label="Hauptnavigation">
      <a href="{{ spice_collection_url }}">Gewürzmischungen</a>
      <a href="{{ set_collection_url }}">Gewürzsets</a>
      <a href="{{ recipes_url }}">Rezepte</a>
      <a href="{{ gift_finder_url }}">Geschenke</a>
      <a href="{{ b2b_url }}">B2B</a>
    </nav>

    <div class="sf-header__actions">
      <form class="sf-search" action="{{ routes.search_url }}" method="get" role="search">
        <label class="visually-hidden" for="Search-{{ section.id }}">Suche</label>
        <input id="Search-{{ section.id }}" type="search" name="q" placeholder="Wonach suchst du?">
        <button type="submit">Suchen</button>
        <div class="sf-search-suggestions-popover" aria-label="Beliebte Suchpfade">
          <a href="{{ routes.search_url }}?type=product&q=bagel">Bagel</a>
          <a href="{{ routes.search_url }}?type=product&q=avocado">Avocado</a>
          <a href="{{ routes.search_url }}?type=product&q=grillen">Grillen</a>
          <a href="{{ routes.search_url }}?type=product&q=geschenk">Geschenk</a>
          <a href="{{ routes.search_url }}?type=product&q=nachf%C3%BCllpack">Nachfüllpack</a>
        </div>
      </form>

      <a class="sf-cart" href="{{ routes.cart_url }}">
        Warenkorb
        <span class="sf-cart__count">{{ cart.item_count }}</span>
      </a>
    </div>

    <form class="sf-mobile-search" action="{{ routes.search_url }}" method="get" role="search">
      <label class="visually-hidden" for="MobileSearch-{{ section.id }}">Suche</label>
      <input id="MobileSearch-{{ section.id }}" type="search" name="q" placeholder="Gericht, Aroma, Set">
      <button type="submit">Suchen</button>
      <div class="sf-search-suggestions-popover" aria-label="Beliebte Suchpfade">
        <a href="{{ routes.search_url }}?type=product&q=bagel">Bagel</a>
        <a href="{{ routes.search_url }}?type=product&q=avocado">Avocado</a>
        <a href="{{ routes.search_url }}?type=product&q=grillen">Grillen</a>
        <a href="{{ routes.search_url }}?type=product&q=geschenk">Geschenk</a>
      </div>
    </form>
  </div>
</header>

{% schema %}
{
  "name": "t:general.header",
  "settings": []
}
{% endschema %}
