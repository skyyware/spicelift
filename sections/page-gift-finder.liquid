{% assign set_collection = collections['gewuerzsets'] %}
{% assign gift_collection = collections['geschenkideen'] %}
{% assign brunch_set = all_products['bio-brunch-bagel-set'] %}
{% assign grill_set = all_products['bio-grillabend-set'] %}
{% assign bagel = all_products['bio-bagel-gewuerz'] %}
{% assign cafe = all_products['bio-cafe-de-paris-gewuerz'] %}
{% assign bruehe = all_products['bio-gemuesebruehe'] %}

<section class="sf-gift-page">
  <div class="sf-page">
    <nav class="sf-breadcrumb" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">Start</a>
      <span aria-hidden="true">/</span>
      <span aria-current="page">{{ page.title }}</span>
    </nav>

    <div class="sf-gift-hero">
      <div>
        <p class="sf-eyebrow">Geschenkfinder</p>
        <h1 class="sf-heading">Geschenke nach Anlass, Budget und Kochstil führen.</h1>
        <p class="sf-copy">
          Gewürzgeschenke scheitern selten am Produkt. Sie scheitern an Auswahlstress.
          Ein guter Finder macht aus vielen schönen Optionen drei klare Kaufpfade.
        </p>
      </div>
      <div class="sf-gift-hero__panel">
        <span>Für Gastgeber</span>
        <span>Für Teams</span>
        <span>Für Kundengeschenke</span>
      </div>
    </div>

    <section class="sf-gift-finder" data-gift-finder aria-labelledby="gift-finder-heading">
      <div class="sf-gift-finder__copy">
        <p class="sf-eyebrow">Interaktive Auswahl</p>
        <h2 id="gift-finder-heading" class="sf-heading sf-heading--medium">Was soll das Geschenk leisten?</h2>
        <p class="sf-copy">
          Der Finder ist bewusst einfach: Ein Klick sortiert nach Situation und zeigt Produkte,
          Begründung und nächsten Schritt. Später kann daraus ein datengetriebenes Quiz wachsen.
        </p>
      </div>

      <div class="sf-gift-finder__surface">
        <div class="sf-gift-choice-grid" role="tablist" aria-label="Geschenktyp auswählen">
          <button class="sf-gift-choice is-active" type="button" data-gift-target="host" aria-selected="true">
            <span>Gastgeber</span>
            <small>20-35 €, sofort verständlich</small>
          </button>
          <button class="sf-gift-choice" type="button" data-gift-target="team" aria-selected="false">
            <span>Team</span>
            <small>Set oder Vorrat, gute Teilbarkeit</small>
          </button>
          <button class="sf-gift-choice" type="button" data-gift-target="client" aria-selected="false">
            <span>Kundengeschenk</span>
            <small>Premium, planbar, B2B-fähig</small>
          </button>
        </div>

        <div class="sf-gift-results">
          <article class="sf-gift-result is-active" data-gift-result="host">
            <div>
              <p class="sf-eyebrow">Empfehlung</p>
              <h3>Brunch-Set plus vertrautes Gewürz.</h3>
              <p>Geringes Erklärbedürfnis, hoher Sofortnutzen und ein natürlicher Einstieg in Wiederkauf.</p>
            </div>
            <div class="sf-grid sf-grid--2">
              {% if brunch_set != blank %}{% render 'product-card-spice', product: brunch_set, compact: true %}{% endif %}
              {% if bagel != blank %}{% render 'product-card-spice', product: bagel, compact: true %}{% endif %}
            </div>
          </article>

          <article class="sf-gift-result" data-gift-result="team" hidden>
            <div>
              <p class="sf-eyebrow">Empfehlung</p>
              <h3>Grill-Set für Teams und saisonale Anlässe.</h3>
              <p>Ein Set reduziert Abstimmung, passt zu Sommer, Office-Küche und gemeinsamen Events.</p>
            </div>
            <div class="sf-grid sf-grid--2">
              {% if grill_set != blank %}{% render 'product-card-spice', product: grill_set, compact: true %}{% endif %}
              {% if cafe != blank %}{% render 'product-card-spice', product: cafe, compact: true %}{% endif %}
            </div>
          </article>

          <article class="sf-gift-result" data-gift-result="client" hidden>
            <div>
              <p class="sf-eyebrow">Empfehlung</p>
              <h3>Premium-Auswahl mit B2B-Anfragepfad.</h3>
              <p>Für größere Mengen zählen Timing, Personalisierung und Lieferfähigkeit mehr als ein einzelner Warenkorb.</p>
            </div>
            <div class="sf-grid sf-grid--2">
              {% if grill_set != blank %}{% render 'product-card-spice', product: grill_set, compact: true %}{% endif %}
              {% if bruehe != blank %}{% render 'product-card-spice', product: bruehe, compact: true %}{% endif %}
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="sf-gift-logic">
      <div>
        <p class="sf-eyebrow">Shopify-Umsetzung</p>
        <h2 class="sf-heading sf-heading--medium">Der einfache Hebel ist nicht ein Rabatt. Es ist Entscheidungssicherheit.</h2>
      </div>
      <div class="sf-gift-logic__grid">
        <article>
          <span>01</span>
          <h3>Budget sichtbar machen</h3>
          <p>Sets und Einzelprodukte werden nicht nur nach Kategorie, sondern nach Geschenkrahmen geführt.</p>
        </article>
        <article>
          <span>02</span>
          <h3>B2B früh trennen</h3>
          <p>Ab Menge, Personalisierung oder Timing führt der Pfad in eine qualifizierte Anfrage.</p>
        </article>
        <article>
          <span>03</span>
          <h3>Nachkauf mitdenken</h3>
          <p>Gute Geschenke erzeugen spätere Einzelprodukt- und Refill-Käufe.</p>
        </article>
      </div>
    </section>

    {% if gift_collection.products.size > 0 or set_collection.products.size > 0 %}
      <section class="sf-related-products">
        <div class="sf-section-intro">
          <div>
            <p class="sf-eyebrow">Direkt kaufbar</p>
            <h2 class="sf-heading sf-heading--medium">Kuratierte Geschenkpfade.</h2>
          </div>
          {% if gift_collection != blank %}
            <a class="sf-button sf-button--ghost" href="{{ gift_collection.url }}">Alle Geschenkideen</a>
          {% elsif set_collection != blank %}
            <a class="sf-button sf-button--ghost" href="{{ set_collection.url }}">Alle Sets</a>
          {% endif %}
        </div>
        <div class="sf-grid sf-grid--3">
          {% if gift_collection.products.size > 0 %}
            {% for product in gift_collection.products limit: 3 %}
              {% render 'product-card-spice', product: product %}
            {% endfor %}
          {% else %}
            {% for product in set_collection.products limit: 3 %}
              {% render 'product-card-spice', product: product %}
            {% endfor %}
          {% endif %}
        </div>
      </section>
    {% endif %}
  </div>
</section>

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Start",
        "item": {{ shop.url | append: routes.root_url | json }}
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": {{ page.title | json }},
        "item": {{ canonical_url | json }}
      }
    ]
  }
</script>

{% schema %}
{
  "name": "Spicelift Geschenkfinder",
  "settings": []
}
{% endschema %}
