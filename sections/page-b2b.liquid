{% assign set_collection = collections['gewuerzsets'] %}
{% assign refill_collection = collections['nachfuellpacks-vorrat'] %}

<section class="sf-b2b-page">
  <div class="sf-page">
    <nav class="sf-breadcrumb" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">Start</a>
      <span aria-hidden="true">/</span>
      <span aria-current="page">{{ page.title }}</span>
    </nav>

    <div class="sf-b2b-hero">
      <p class="sf-eyebrow">B2B & Firmengeschenke</p>
      <h1 class="sf-heading">Business-Geschenke, Vorrat und White Label ohne Umwege.</h1>
      <p class="sf-copy">
        Für Geschäftskunden zählen Menge, Anlass, Personalisierung, Lieferzeit und Wiederbestellung
        direkt von Anfang an.
      </p>
      <div class="sf-hero__actions">
        {% if set_collection != blank %}
          <a class="sf-button" href="{{ set_collection.url }}">Geschenksets ansehen</a>
        {% endif %}
        {% if refill_collection != blank %}
          <a class="sf-button sf-button--ghost" href="{{ refill_collection.url }}">Vorrat & Refill</a>
        {% endif %}
      </div>
    </div>

    <div class="sf-b2b-grid">
      <article class="sf-b2b-card">
        <span>01</span>
        <h2>Firmengeschenke</h2>
        <p>Kuratierte Sets mit klaren Mengenstaffeln, Geschenknotiz und Versandhinweis.</p>
      </article>
      <article class="sf-b2b-card">
        <span>02</span>
        <h2>Gastro & Teams</h2>
        <p>Vorratsgrößen und Gastro-Varianten sind eigenständig sichtbar statt versteckt in Varianten.</p>
      </article>
      <article class="sf-b2b-card">
        <span>03</span>
        <h2>Private Label</h2>
        <p>Ein kurzer Qualifizierungsflow trennt Muster, Mindestmenge, Labeling und Lieferfenster.</p>
      </article>
    </div>

    <section class="sf-section-intro sf-b2b-next">
      <div>
        <p class="sf-eyebrow">Für Geschäftskunden</p>
        <h2 class="sf-heading sf-heading--medium">Wenige Angaben reichen für eine passende Anfrage.</h2>
        <p class="sf-copy">
          Wer größere Mengen plant, braucht schnell Klarheit über Anlass, Stückzahl,
          Budget, Personalisierung und Lieferfenster.
        </p>
      </div>
      <div class="sf-feature-list">
        <div class="sf-feature-item" style="--dot:var(--sf-sage)"><div><h3>Richtiger Einstieg</h3><p>Geschenk, Gastro und Private Label führen zu unterschiedlichen Fragen.</p></div></div>
        <div class="sf-feature-item" style="--dot:var(--sf-clay)"><div><h3>Direkt kaufbar</h3><p>Sets und Vorratsgrößen bleiben bestellbar, auch wenn größere Mengen angefragt werden.</p></div></div>
        <div class="sf-feature-item" style="--dot:var(--sf-berry)"><div><h3>Klarer Bedarf</h3><p>Menge, Anlass, Timing und Personalisierung sind vor dem Gespräch greifbar.</p></div></div>
      </div>
    </section>

    <section class="sf-b2b-inquiry" aria-labelledby="b2b-inquiry-heading">
      <div>
        <p class="sf-eyebrow">Anfragepfad</p>
        <h2 id="b2b-inquiry-heading" class="sf-heading sf-heading--medium">Wenige Angaben, sofort qualifizierbar.</h2>
        <p class="sf-copy">
          Menge, Anlass und Zeitfenster entscheiden, ob Geschenksets, Vorrat oder Private Label
          der richtige Einstieg sind.
        </p>
      </div>

      {% form 'contact', class: 'sf-b2b-form' %}
        {% if form.posted_successfully? %}
          <p class="sf-form-success">Danke. Die Anfrage wurde vorbereitet.</p>
        {% endif %}
        {% if form.errors %}
          <div class="sf-form-error">{{ form.errors | default_errors }}</div>
        {% endif %}
        <input type="hidden" name="contact[subject]" value="B2B Anfrage Spicelift">
        <div class="sf-form-row">
          <label>
            Name
            <input type="text" name="contact[name]" autocomplete="name" required>
          </label>
          <label>
            E-Mail
            <input type="email" name="contact[email]" autocomplete="email" required>
          </label>
        </div>
        <div class="sf-form-row">
          <label>
            Unternehmen
            <input type="text" name="contact[company]" autocomplete="organization">
          </label>
          <label>
            Stückzahl
            <input type="text" name="contact[quantity]" inputmode="numeric" placeholder="z. B. 50 Sets">
          </label>
        </div>
        <label>
          Bedarf
          <select name="contact[request_type]">
            <option>Firmengeschenke</option>
            <option>Gastro & Teams</option>
            <option>Private Label</option>
            <option>Wiederverkauf</option>
          </select>
        </label>
        <label>
          Kontext
          <textarea name="contact[body]" rows="5" placeholder="Anlass, gewünschtes Timing, Personalisierung, Budgetrahmen oder offene Fragen"></textarea>
        </label>
        <button class="sf-button" type="submit">Anfragen</button>
      {% endform %}
    </section>

    {% if set_collection.products.size > 0 %}
      <section class="sf-related-products">
        <div class="sf-section-intro">
          <div>
            <p class="sf-eyebrow">Direkt kaufbar</p>
            <h2 class="sf-heading sf-heading--medium">Sets als schneller Business-Einstieg.</h2>
          </div>
          <a class="sf-button sf-button--ghost" href="{{ set_collection.url }}">Alle Sets</a>
        </div>
        <div class="sf-grid sf-grid--2">
          {% for product in set_collection.products limit: 2 %}
            {% render 'product-card-spice', product: product %}
          {% endfor %}
        </div>
      </section>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Spicelift B2B Page",
  "settings": []
}
{% endschema %}
