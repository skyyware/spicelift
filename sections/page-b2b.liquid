{% assign set_collection = collections['gewuerzsets'] %}
{% assign refill_collection = collections['nachfuellpacks-vorrat'] %}

<section class="sf-b2b-page">
  <div class="sf-page">
    <nav class="sf-breadcrumb" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">Start</a>
      <span aria-hidden="true">/</span>
      <span aria-current="page">{{ page.title }}</span>
    </nav>

    <div class="sf-b2b-hero">
      <p class="sf-eyebrow">B2B & Corporate Gifts</p>
      <h1 class="sf-heading">Gewürzgeschenke und Vorrat ohne Anfrage-Reibung.</h1>
      <p class="sf-copy">
        Geschäftskunden brauchen andere Kaufpfade als D2C-Kundschaft: Menge, Anlass,
        Personalisierung, Lieferzeit und Wiederbestellung müssen früh sichtbar werden.
      </p>
      <div class="sf-hero__actions">
        {% if set_collection != blank %}
          <a class="sf-button" href="{{ set_collection.url }}">Geschenksets ansehen</a>
        {% endif %}
        {% if refill_collection != blank %}
          <a class="sf-button sf-button--ghost" href="{{ refill_collection.url }}">Vorrat & Refill</a>
        {% endif %}
      </div>
    </div>

    <div class="sf-b2b-grid">
      <article class="sf-b2b-card">
        <span>01</span>
        <h2>Corporate Gifts</h2>
        <p>Kuratierte Sets mit klaren Mengenstaffeln, Geschenknotiz und Versandhinweis.</p>
      </article>
      <article class="sf-b2b-card">
        <span>02</span>
        <h2>Gastro & Teams</h2>
        <p>Vorratsgrößen und Gastro-Varianten werden als eigener Pfad statt versteckter Variante geführt.</p>
      </article>
      <article class="sf-b2b-card">
        <span>03</span>
        <h2>Private Label</h2>
        <p>Ein kurzer Qualifizierungsflow trennt Muster, Mindestmenge, Labeling und Lieferfenster.</p>
      </article>
    </div>

    <section class="sf-section-intro sf-b2b-next">
      <div>
        <p class="sf-eyebrow">Umsetzung in Shopify</p>
        <h2 class="sf-heading sf-heading--medium">Einfacher Hebel, große Wirkung.</h2>
        <p class="sf-copy">
          Diese Seite ist bewusst schlank: Sie zeigt, wie eine Shopify-Theme-Strecke B2B-Kontext
          aufnehmen kann, ohne sofort eine separate App oder ein komplexes Portal einzuführen.
        </p>
      </div>
      <div class="sf-feature-list">
        <div class="sf-feature-item" style="--dot:var(--sf-sage)"><div><h3>Segmentierter Einstieg</h3><p>Geschenk, Gastro und Private Label werden als unterschiedliche Jobs-to-be-done behandelt.</p></div></div>
        <div class="sf-feature-item" style="--dot:var(--sf-clay)"><div><h3>Collection-Anbindung</h3><p>Sets und Vorratsgrößen bleiben kaufbar statt reine Kontaktstrecke zu sein.</p></div></div>
        <div class="sf-feature-item" style="--dot:var(--sf-berry)"><div><h3>Später erweiterbar</h3><p>Der Pfad kann auf Shopify Forms, B2B Catalogs, Company Accounts oder CRM-Integration wachsen.</p></div></div>
      </div>
    </section>

    {% if set_collection.products.size > 0 %}
      <section class="sf-related-products">
        <div class="sf-section-intro">
          <div>
            <p class="sf-eyebrow">Direkt kaufbar</p>
            <h2 class="sf-heading sf-heading--medium">Sets als schneller B2B-Einstieg.</h2>
          </div>
          <a class="sf-button sf-button--ghost" href="{{ set_collection.url }}">Alle Sets</a>
        </div>
        <div class="sf-grid sf-grid--2">
          {% for product in set_collection.products limit: 2 %}
            {% render 'product-card-spice', product: product %}
          {% endfor %}
        </div>
      </section>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Spicelift B2B Page",
  "settings": []
}
{% endschema %}
