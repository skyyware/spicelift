<footer class="sf-footer full-width">
  <div class="sf-page sf-footer__grid">
    <div>
      <a class="sf-logo" href="{{ routes.root_url }}">
        <span class="sf-logo__text">
          <span class="sf-logo__wordmark">SPICELIFT</span>
          <span class="sf-logo__tagline">Bio Gewürzmanufaktur</span>
        </span>
      </a>
      <p>
        Bio-Gewürze, kuratierte Sets und Rezeptideen für Alltag, Geschenk und
        professionelle Küche.
      </p>
    </div>
    <div>
      <h3>Zahlungsarten</h3>
      <ul class="sf-footer-payments" aria-label="Zahlungsarten">
        {% if shop.enabled_payment_types != empty %}
          {% for type in shop.enabled_payment_types %}
            <li>{{ type | payment_type_svg_tag: class: 'sf-footer-payment-icon' }}</li>
          {% endfor %}
        {% else %}
          {% assign fallback_payment_types = 'paypal,visa,master' | split: ',' %}
          {% for type in fallback_payment_types %}
            <li>{{ type | payment_type_svg_tag: class: 'sf-footer-payment-icon' }}</li>
          {% endfor %}
        {% endif %}
      </ul>
    </div>
    <div>
      <h3>Versandoptionen</h3>
      <ul class="sf-footer-service" aria-label="Versandoptionen">
        <li>DHL Paket</li>
        <li>Packstation möglich</li>
        <li>Sendungsverfolgung</li>
      </ul>
    </div>
    <div>
      <h3>Service</h3>
      <ul class="sf-footer-service" aria-label="Serviceversprechen">
        <li>Bio-Qualität</li>
        <li>Sichere Zahlung</li>
        <li>Versandkostenfrei ab 40 €</li>
      </ul>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "t:general.footer",
  "settings": []
}
{% endschema %}
