{% assign spice_collection_url = routes.collections_url | append: '/gewuerzmischungen' %}
{% assign set_collection_url = routes.collections_url | append: '/gewuerzsets' %}
{% assign recipe_url = routes.root_url | append: '#recipe-to-cart' %}
{% assign gifts_url = routes.root_url | append: '#gifts' %}
{% assign b2b_url = routes.root_url | append: '#b2b' %}

<footer class="sf-footer">
  <div class="sf-page sf-footer__grid">
    <div>
      <a class="sf-logo" href="{{ routes.root_url }}">
        <span class="sf-logo__wordmark">SPICELIFT</span>
        <span class="sf-logo__tagline">Bio Gewürzmanufaktur</span>
      </a>
      <p>
        Bio-Gewürze, kuratierte Sets und Rezeptideen für Alltag, Geschenk und
        professionelle Küche.
      </p>
    </div>
    <div>
      <h3>Shop</h3>
      <p><a href="{{ spice_collection_url }}">Gewürzmischungen</a></p>
      <p><a href="{{ set_collection_url }}">Gewürzsets</a></p>
      <p><a href="{{ recipe_url }}">Rezepte</a></p>
    </div>
    <div>
      <h3>Anlässe</h3>
      <p><a href="{{ gifts_url }}">Geschenke</a></p>
      <p><a href="{{ b2b_url }}">B2B</a></p>
      <p><a href="{{ spice_collection_url }}">Vorrat & Nachfüllen</a></p>
    </div>
    <div>
      <h3>Service</h3>
      <p>Versandkostenfrei ab 40 EUR</p>
      <p>Bio-Qualität</p>
      <p>Sichere Zahlung</p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "t:general.footer",
  "settings": []
}
{% endschema %}
