{% assign accent = product.metafields.custom.accent_color.value | default: '#e85d36' %}
{% assign subtitle = product.metafields.custom.subtitle.value | default: product.type %}
{% assign usage = product.metafields.custom.usage.value | default: 'Gewürzküche' %}
{% assign product_asset = 'spice-product-' | append: product.handle | append: '.jpg' %}
{% assign current_variant = product.selected_or_first_available_variant %}

<article class="sf-product-card" style="--spice-accent: {{ accent }}">
  <a class="sf-product-card__image" href="{{ product.url }}" aria-label="{{ product.title }}">
    <span class="sf-bio-badge">Bio</span>
    {% if product.featured_image %}
      {% render 'image', image: product.featured_image, width: 720, height: 720, crop: 'center' %}
    {% else %}
      <img src="{{ product_asset | asset_url }}" width="720" height="720" loading="lazy" alt="{{ product.title | escape }}">
    {% endif %}
  </a>

  <div class="sf-product-card__content">
    <span class="sf-rating">★★★★★ <span style="color:var(--sf-muted);">4,9</span></span>
    <h3><a href="{{ product.url }}">{{ product.title }}</a></h3>
    <p>{{ subtitle }}</p>
    <div class="sf-chip-row">
      <span class="sf-chip">{{ usage }}</span>
      <span class="sf-chip">Nachfüllbar</span>
    </div>
    <div class="sf-product-card__meta">
      <span class="sf-price">ab {{ product.price_min | money_without_trailing_zeros }}</span>
      {% if current_variant.available %}
        {% form 'product', product %}
          <input type="hidden" name="id" value="{{ current_variant.id }}">
          <input type="hidden" name="quantity" value="1">
          <button class="sf-quick-add" type="submit">Hinzufügen</button>
        {% endform %}
      {% else %}
        <span class="sf-quick-add">Ausverkauft</span>
      {% endif %}
    </div>
  </div>
</article>
