[
  {
    "name": "theme_info",
    "theme_name": "Spicelift Premium Store",
    "theme_version": "1.0.0",
    "theme_author": "Skyyware",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "t:general.typography",
    "settings": [
      {
        "type": "header",
        "content": "t:general.fonts"
      },
      {
        "type": "font_picker",
        "id": "type_primary_font",
        "default": "work_sans_n4",
        "label": "t:general.primary"
      }
    ]
  },
  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "t:labels.page_width",
        "options": [
          {
            "value": "90rem",
            "label": "t:options.page_width.narrow"
          },
          {
            "value": "110rem",
            "label": "t:options.page_width.wide"
          }
        ],
        "default": "90rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "t:labels.page_margin",
        "default": 20
      }
    ]
  },
  {
    "name": "t:general.colors",
    "settings": [
      {
        "type": "color",
        "id": "background_color",
        "default": "#FFFFFF",
        "label": "t:labels.background"
      },
      {
        "type": "color",
        "id": "foreground_color",
        "default": "#333333",
        "label": "t:labels.foreground"
      },
      {
        "type": "range",
        "id": "input_corner_radius",
        "min": 0,
        "max": 10,
        "step": 1,
        "unit": "px",
        "label": "t:labels.input_corner_radius",
        "default": 4
      }
    ]
  },
  {
    "name": "Brand & SEO",
    "settings": [
      {
        "type": "text",
        "id": "homepage_meta_title",
        "label": "Homepage SEO title",
        "default": "Spicelift | Premium Bio-Gewürze, Sets und Rezepte"
      },
      {
        "type": "textarea",
        "id": "homepage_meta_description",
        "label": "Homepage meta description",
        "default": "Spicelift verbindet Bio-Gewürze, kuratierte Sets, Rezeptideen und Nachfüllpacks in einem klaren, schnellen Einkaufserlebnis."
      },
      {
        "type": "paragraph",
        "content": "The theme uses spicelift-social-share.jpg as OpenGraph fallback when a page has no featured image. Shopify Admin can additionally set Online Store > Preferences > Social sharing image."
      }
    ]
  }
]
